pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/Dhanyaa-bot/Devops-practice.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 3000:3000 app'
            }
        }
    }

